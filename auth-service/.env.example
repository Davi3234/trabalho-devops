APP_NAME=Auth-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=pgsql
DB_HOST=db-auth
DB_PORT=5432
DB_DATABASE=auth
DB_USERNAME= postgres
DB_PASSWORD=secret

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

JWT_SECRET=secret-key
JWT_EXPIRES_IN=3600
