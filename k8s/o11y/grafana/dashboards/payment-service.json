{
  "annotations": { "list": [] },
  "description": "Métricas do Payment Service",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Requisições HTTP (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(payment_service_http_requests_total[5m])",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "Latência HTTP p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.95, rate(payment_service_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "Total de Requisições",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(payment_service_http_requests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "Erros HTTP (4xx/5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(payment_service_http_requests_total{status=~\"4..|5..\"})",
          "legendFormat": "Erros",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "id": 5,
      "title": "Memória Residente (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "payment_service_process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "Memória PHP",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["payment-service"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Payment Service",
  "uid": "payment-service"
}
