  },
  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": 456,\n  \"shippingCost\": 10.0,\n  \"items\": [\n    {\n      \"productId\": 123,\n      \"productName\": \"Product A\",\n      \"unitPrice\": 50.0,\n      \"quantity\": 2\n    }\n  ]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "orders"]
        }
      }
    },
    {
